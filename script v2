    local function clampPanelOffset(offsetX, offsetY)
        local camera = Workspace.CurrentCamera
        if not camera then
            return offsetX, offsetY
        end
        local viewport = camera.ViewportSize
        local maxX = math.max(0, viewport.X - panel.AbsoluteSize.X - 8)
        local maxY = math.max(0, viewport.Y - panel.AbsoluteSize.Y - 8)
        return math.clamp(offsetX, 0, maxX), math.clamp(offsetY, 0, maxY)
    end

    local function updateDrag(input)
        local delta = input.Position - dragStart
        local targetX = startPos.X.Offset + delta.X
        local targetY = startPos.Y.Offset + delta.Y
        local clampedX, clampedY = clampPanelOffset(targetX, targetY)
        panel.Position = UDim2.fromOffset(clampedX, clampedY)
    end

